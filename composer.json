{
    "name": "spatie/there-there-cli",
    "description": "A standalone CLI tool for the There There helpdesk.",
    "keywords": ["there-there", "spatie", "helpdesk", "cli", "support"],
    "homepage": "https://there-there.app",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/spatie/there-there-cli/issues",
        "source": "https://github.com/spatie/there-there-cli"
    },
    "authors": [
        {
            "name": "Spatie",
            "email": "info@spatie.be",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "illuminate/http": "^12.53",
        "laravel-zero/framework": "^12.0.2",
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2",
        "spatie/laravel-openapi-cli": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "format": "vendor/bin/pint"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["builds/there-there"]
}
